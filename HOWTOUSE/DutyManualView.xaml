<UserControl x:Class="HOWTOUSE.DutyManualView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="White"/><Setter Property="BorderBrush" Value="#D8E0EA"/>
            <Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="8"/><Setter Property="Padding" Value="16"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0E91F5"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="#EFF6FF"/><Setter Property="Foreground" Value="#0369A1"/><Setter Property="BorderBrush" Value="#BFDBFE"/>
            <Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="10,6"/><Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBox"><Setter Property="BorderBrush" Value="#CBD5E1"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="9,7"/></Style>
    </UserControl.Resources>
    <Border Style="{StaticResource Panel}">
        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="210"/><ColumnDefinition Width="16"/><ColumnDefinition Width="280"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Grid Grid.ColumnSpan="5">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="당직 매뉴얼" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="분류를 선택해 매뉴얼을 읽고, 필요한 사진·PPT·확인 쿼리를 한 곳에서 관리하세요." Margin="0,4,0,0" Foreground="#64748B"/></StackPanel>
                <Button x:Name="NewManualPostButton" Grid.Column="1" Content="새 매뉴얼" Style="{StaticResource PrimaryButton}" Click="NewManualPostButton_Click"/>
            </Grid>
            <Border Grid.Row="1" Grid.Column="0" Margin="0,18,0,0" Background="#F8FAFC" CornerRadius="6" Padding="8">
                <StackPanel><TextBlock Text="카테고리" FontWeight="Bold" Margin="6,4,0,8"/>
                    <TreeView x:Name="CategoryTreeView" SelectedItemChanged="CategoryTreeView_SelectedItemChanged" PreviewMouseRightButtonDown="CategoryTreeView_PreviewMouseRightButtonDown">
                        <TreeView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="하위 폴더 추가" Click="AddManualCategoryButton_Click"/>
                                <Separator/>
                                <MenuItem Header="폴더 이름 변경" Click="RenameManualCategoryButton_Click"/>
                                <MenuItem Header="위로 이동" Click="MoveManualCategoryUpButton_Click"/>
                                <MenuItem Header="아래로 이동" Click="MoveManualCategoryDownButton_Click"/>
                                <Separator/>
                                <MenuItem Header="폴더 삭제" Click="DeleteManualCategoryButton_Click"/>
                            </ContextMenu>
                        </TreeView.ContextMenu>
                    </TreeView>
                </StackPanel>
            </Border>
            <Grid Grid.Row="1" Grid.Column="2" Margin="0,18,0,0"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <TextBox x:Name="DutySearchTextBox" ToolTip="제목, 내용, 쿼리에서 검색" TextChanged="DutySearchTextBox_TextChanged"/>
                <ListBox x:Name="DutyListBox" Grid.Row="1" Margin="0,10,0,0" BorderThickness="0" SelectionChanged="DutyListBox_SelectionChanged">
                    <ListBox.ItemTemplate><DataTemplate><Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8"><StackPanel>
                        <TextBlock Text="{Binding Category}" Foreground="#0E91F5" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,3,0,0"/>
                        <TextBlock Text="{Binding LastModifiedLabel}" Foreground="#94A3B8" FontSize="11" Margin="0,5,0,0"/>
                    </StackPanel></Border></DataTemplate></ListBox.ItemTemplate>
                </ListBox>
            </Grid>
            <Border Grid.Row="1" Grid.Column="4" Margin="0,18,0,0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <StackPanel><TextBlock x:Name="ManualEditorTitleTextBlock" Text="매뉴얼을 선택하세요" FontSize="17" FontWeight="Bold"/><TextBlock Text="읽기 모드에서 필요한 자료와 점검 쿼리를 바로 확인할 수 있습니다." Foreground="#64748B" Margin="0,4,0,12" TextWrapping="Wrap"/></StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"><StackPanel x:Name="ManualEditorPanel">
                        <TextBlock Text="카테고리" FontWeight="SemiBold"/><ComboBox x:Name="ManualCategoryComboBox" Margin="0,5,0,10"/>
                        <TextBlock Text="제목" FontWeight="SemiBold"/><TextBox x:Name="ManualTitleInput" Margin="0,5,0,10"/>
                        <TextBlock Text="업무 안내" FontWeight="SemiBold"/><TextBox x:Name="ManualDetailInput" Margin="0,5,0,10" MinHeight="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                        <TextBlock Text="확인/조치 쿼리" FontWeight="SemiBold"/><TextBox x:Name="ManualQueryInput" Margin="0,5,0,10" MinHeight="88" FontFamily="Consolas" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" ToolTip="실행 전 대상 DB와 조건을 반드시 확인하세요."/>
                        <Grid Margin="0,0,0,7"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="첨부 자료" FontWeight="SemiBold"/><Button x:Name="AddAttachmentButton" Grid.Column="1" Content="사진/PPT 추가" Style="{StaticResource OutlineButton}" Click="AddAttachmentButton_Click"/></Grid>
                        <TextBlock Text="사진은 미리보기로, PPT/PPTX는 파일명으로 표시되며 더블 클릭하면 열립니다." FontSize="11" Foreground="#64748B" TextWrapping="Wrap"/>
                        <ListBox x:Name="AttachmentListBox" Margin="0,7,0,0" BorderThickness="0" MouseDoubleClick="AttachmentListBox_MouseDoubleClick"><ListBox.ItemTemplate><DataTemplate><Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,6"><StackPanel>
                            <Image Source="{Binding FilePath}" MaxHeight="160" Stretch="Uniform" Visibility="{Binding ImageVisibility}"/><TextBlock Text="{Binding DisplayName}" Margin="0,5,0,0"/><Button Content="첨부 삭제" Tag="{Binding}" HorizontalAlignment="Left" Margin="0,5,0,0" Click="RemoveAttachmentButton_Click"/>
                        </StackPanel></Border></DataTemplate></ListBox.ItemTemplate></ListBox>
                    </StackPanel></ScrollViewer>
                    <StackPanel Grid.Row="2"><Button x:Name="SaveManualButton" Content="저장" Margin="0,14,0,0" Style="{StaticResource PrimaryButton}" Click="SaveManualButton_Click"/><TextBlock x:Name="ManualModifiedTextBlock" Foreground="#64748B" FontSize="11" Margin="0,8,0,0"/></StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
